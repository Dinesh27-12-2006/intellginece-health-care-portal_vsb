# Ignore sensitive local configuration
.env
.env.local
.env.production
.env.development

# System files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Optional local files
test-conn.js
test-insert.js
test-*.js
*.test.local.js

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies (if you add node modules later)
node_modules/
package-lock.json
yarn.lock

# Build outputs (if you add a build step)
dist/
build/
.cache/

# Temporary files
tmp/
temp/
*.tmp
